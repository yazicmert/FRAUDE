# FRAUDE web API — ortam değişkenleri örneği.
# Gerçek .env dosyası git'e girmez (bkz. .dockerignore / kök .gitignore).

# Dinlenecek port (yerelde 8787; frontend .env.example ile eşleşir).
PORT=8787

# Log seviyesi.
RUST_LOG=info

# CORS: izin verilen origin(ler), virgülle. Tanımsızsa yerel geliştirmede
# tüm origin'lere kimlik bilgisiz izin verilir. Üretimde Vercel prod origin'i:
# ALLOWED_ORIGIN=https://fraude.vercel.app

# ── Modül registry (FMUP) ─────────────────────────────────────
# Sunucunun sunacağı imzalı registry statik dosyalarının kök dizini.
# scripts/registry-build.mjs bu dizini üretir; sunucu olduğu gibi sunar.
FRAUDE_REGISTRY_DATA_DIR=.fraude-registry

# ── Faz 2+ (auth + veritabanı) ────────────────────────────────
# DATABASE_URL=postgres://user:pass@host:5432/fraude
# SUPABASE_JWKS_URL=https://<proje>.supabase.co/auth/v1/.well-known/jwks.json

# ── Faz 3 (AI anahtar şifreleme) ──────────────────────────────
# 32 baytlık base64 master key (envelope encryption). Örnek üretim:
#   openssl rand -base64 32
# FRAUDE_KEY_ENC_SECRET=
