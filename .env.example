# FRAUDE Web sends the same command contract used by Tauri to this API.
# Leave unset for UI-only local development.
VITE_FRAUDE_API_URL=http://localhost:8787
VITE_FRAUDE_REGISTRY_URL=http://localhost:8787
# Production: JSON array of pinned Ed25519 public keys. Localhost may use the ephemeral dev key.
VITE_FRAUDE_TRUST_KEYS=

# Registry server only. Never prefix the review token with VITE_ or expose it to clients.
FRAUDE_REGISTRY_DATA_DIR=.fraude-registry
FRAUDE_REGISTRY_REVIEW_TOKEN=replace-with-a-long-random-server-secret
